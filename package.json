{
  "name": "ward-protocol",
  "version": "0.1.0",
  "description": "WARD (Web Access Rights Declaration) — server-enforced AI bot content control",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "SPECIFICATION.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ward",
    "ai",
    "bot",
    "crawler",
    "privacy",
    "gdpr",
    "content-control",
    "middleware",
    "nextjs"
  ],
  "author": "Slava Spitsyn <slava@getward.org>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vaclavnew/ward-protocol.git"
  },
  "homepage": "https://getward.org",
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsup": "^8.0.0",
    "vitest": "^3.0.0",
    "@types/node": "^22.0.0"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
